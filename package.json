{
  "name": "wazir-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "A local-first supervisor for AI coding agents.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "^20 || ^22"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' run build",
    "typecheck": "pnpm -r --filter './packages/**' run typecheck",
    "clean": "pnpm -r --filter './packages/**' run clean",
    "dev": "bash scripts/dev.sh",
    "dev:hub": "tsx packages/cli/src/bin.ts hub",
    "dev:worker": "tsx packages/cli/src/bin.ts worker",
    "wazir": "bash scripts/wazir.sh",
    "wazir:init": "bash scripts/wazir.sh init",
    "wazir:status": "bash scripts/wazir.sh status",
    "wazir:log": "bash scripts/wazir.sh log",
    "wazir:doctor": "bash scripts/wazir.sh doctor",
    "wazir:install-service": "bash scripts/wazir.sh install-service",
    "wazir:uninstall-service": "bash scripts/wazir.sh uninstall-service",
    "lint": "pnpm -r --filter './packages/**' run lint --if-present",
    "test": "pnpm -r --filter './packages/**' run test --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
